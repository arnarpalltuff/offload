# ============================================
# Offload — Environment Variables
# ============================================
# Leave Supabase + Stripe empty to run in DEMO MODE
# (all data stored in localStorage, no backend needed)

# --- Supabase (leave empty for demo mode) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic API (required for live AI features) ---
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# --- App URL (REQUIRED in production) ---
# Set to your production domain, e.g. https://offload.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Stripe (leave empty for demo mode) ---
# Required for paid subscriptions
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Optional: comma-separated list of allowed price IDs for extra security
# STRIPE_ALLOWED_PRICE_IDS=price_xxx,price_yyy
